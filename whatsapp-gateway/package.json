{
  "name": "alavanch-whatsapp-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Gateway WhatsApp Alavanch — sessão Baileys persistente, QR Code, envio/recebimento e sincronização de histórico recente. Encaminha eventos para o Supabase via webhook.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --loader tsx/esm src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start:prod": "node dist/index.js",
    "health": "curl -fsS http://localhost:${PORT:-8788}/health"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.7",
    "fastify": "^4.28.1",
    "pino": "^9.3.2",
    "qrcode": "^1.5.4",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
