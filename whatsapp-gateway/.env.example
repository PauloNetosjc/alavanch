# Secret compartilhado com as Supabase Edge Functions (header x-whatsapp-api-secret)
WHATSAPP_GATEWAY_SECRET=troque-este-valor-por-um-segredo-forte

# Porta HTTP
PORT=8788

# Diretório onde as sessões Baileys serão persistidas (montar volume em produção!)
SESSIONS_DIR=./sessions

# Webhook para notificar o Supabase de eventos (QR atualizado, mensagens recebidas, conexão)
# Aponte para a edge function whatsapp-webhook do seu projeto Supabase
SUPABASE_WEBHOOK_URL=https://SEU_PROJECT_REF.functions.supabase.co/whatsapp-webhook
SUPABASE_WEBHOOK_SECRET=mesmo-segredo-configurado-no-edge-function

NODE_ENV=development
