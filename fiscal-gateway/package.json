{
  "name": "alavanch-fiscal-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Gateway fiscal mTLS Alavanch — transmissão NF-e homologação para SEFAZ usando certificado A1 (cliente TLS). Não persiste certificado nem senha.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --loader tsx/esm src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start:prod": "node dist/index.js",
    "health": "curl -fsS http://localhost:${PORT:-8787}/health"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "node-forge": "^1.3.1",
    "undici": "^6.19.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/node-forge": "^1.3.11",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
